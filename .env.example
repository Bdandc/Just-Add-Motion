# fal.ai — SERVER-SIDE ONLY. Set in the Vercel project env (Production + Preview).
# Routed through /api/fal/proxy; never exposed to the browser. (No VITE_ prefix.)
FAL_KEY="your-fal-api-key"

# Gemini — SERVER-SIDE ONLY. Set in the Vercel project env (Production + Preview).
# Routed through /api/gemini; never exposed to the browser. (No VITE_ prefix.)
JAM_GEMINI_API_KEY="your-gemini-api-key"

# Supabase — public anon key (safe in the client, protected by RLS).
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
